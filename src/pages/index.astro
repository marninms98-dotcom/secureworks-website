<script>
  /**
   * Homepage Enhancements
   * - Ambient cursor glow
   * - Counter animations on stats
   */
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  function initHomepage() {
    // --- Ambient Cursor Glow ---
    const glow = document.getElementById('ambient-glow');
    if (glow && window.innerWidth > 768) {
      let glowActive = false;
      document.addEventListener('mousemove', (e) => {
        if (!glowActive) {
          glow.classList.add('is-active');
          glowActive = true;
        }
        glow.style.setProperty('--glow-x', e.clientX + 'px');
        glow.style.setProperty('--glow-y', e.clientY + 'px');
      });
    }

    // --- Counter Animations ---
    const statSection = document.getElementById('stats-section');
    if (statSection) {
      const stats = statSection.querySelectorAll('.stat');
      stats.forEach((stat) => {
        const target = parseInt(stat.getAttribute('data-count') || '0', 10);
        const suffix = stat.getAttribute('data-suffix') || '';
        const numberEl = stat.querySelector('.stat__number');
        if (!numberEl) return;

        // Animate counter when scrolled into view
        const counter = { val: 0 };
        ScrollTrigger.create({
          trigger: statSection,
          start: 'top 80%',
          once: true,
          onEnter: () => {
            gsap.to(counter, {
              val: target,
              duration: 2,
              ease: 'power2.out',
              onUpdate: () => {
                const current = Math.round(counter.val);
                // Format with comma for 1000+
                const formatted = current >= 1000
                  ? current.toLocaleString()
                  : String(current);
                numberEl.textContent = formatted + suffix;
              },
            });
          },
        });
      });
    }
  }

  // Run on initial load
  initHomepage();

  // Re-run after View Transitions
  document.addEventListener('astro:after-swap', () => {
    requestAnimationFrame(initHomepage);
  });
</script>
