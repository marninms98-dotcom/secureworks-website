---
/**
 * BaseLayout.astro
 * Shared layout for all pages: head, header, footer, View Transitions.
 * Every page imports this as a wrapper.
 */
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const {
  title,
  description = 'SecureWorks Group — Perth\'s outdoor living specialists. Insulated patios, fencing, decking & more. 300+ jobs completed.',
  ogImage = '/images/hero-patio.jpg',
} = Astro.props;

// Navigation links
const navLinks = [
  { label: 'Patios', href: '/patios-perth/' },
  { label: 'Fencing', href: '/fencing-perth/' },
  { label: 'Decking', href: '/decking-perth/' },
  { label: 'Projects', href: '/projects/' },
  { label: 'About', href: '/about/' },
  { label: 'Contact', href: '/contact/' },
];

// Service areas for footer
const serviceAreas = [
  'Joondalup', 'Wanneroo', 'Stirling', 'Balcatta',
  'Scarborough', 'Hillarys', 'Mindarie', 'Clarkson',
  'Ellenbrook', 'Midland',
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/images/secureworks-icon.svg" />

    <!-- Google Fonts: Plus Jakarta Sans -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;700;800&display=swap"
      rel="stylesheet"
    />

    <title>{title} | SecureWorks Group</title>

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Social Sharing -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | SecureWorks Group`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:locale" content="en_AU" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | SecureWorks Group`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- Geo tags for local SEO -->
    <meta name="geo.region" content="AU-WA" />
    <meta name="geo.placename" content="Perth" />

    <!-- Astro View Transitions -->
    <ViewTransitions />

    <!-- UTM / GCLID Attribution Capture -->
    <script is:inline>
    (function captureAttribution() {
      var params = new URLSearchParams(window.location.search);
      var keys = ['utm_source','utm_medium','utm_campaign','utm_term','utm_content','gclid'];
      var found = {};
      var hasAny = false;
      keys.forEach(function(k) {
        var v = params.get(k);
        if (v) { found[k] = v; hasAny = true; }
      });
      if (hasAny && !sessionStorage.getItem('sw_attribution')) {
        found.landing_page = window.location.pathname;
        found.captured_at = new Date().toISOString();
        sessionStorage.setItem('sw_attribution', JSON.stringify(found));
      }
    })();
    document.addEventListener('astro:after-swap', function() {
      var params = new URLSearchParams(window.location.search);
      var keys = ['utm_source','utm_medium','utm_campaign','utm_term','utm_content','gclid'];
      var found = {};
      var hasAny = false;
      keys.forEach(function(k) {
        var v = params.get(k);
        if (v) { found[k] = v; hasAny = true; }
      });
      if (hasAny && !sessionStorage.getItem('sw_attribution')) {
        found.landing_page = window.location.pathname;
        found.captured_at = new Date().toISOString();
        sessionStorage.setItem('sw_attribution', JSON.stringify(found));
      }
    });
    </script>
  </head>

  <body>
    <!-- ========== HEADER ========== -->
    <header class="site-header">
      <div class="container header-inner">
        <!-- Logo -->
        <a href="/" class="logo" aria-label="SecureWorks Group — Home">
          <img
            src="/images/SecureWorks Group Main.svg"
            alt="SecureWorks Group"
            width="180"
            height="40"
          />
        </a>

        <!-- Desktop Navigation -->
        <nav class="nav-desktop" aria-label="Main navigation">
          {navLinks.map((link) => (
            <a href={link.href} class="nav-link">{link.label}</a>
          ))}
        </nav>

        <!-- Phone + Hours (trust signal — visible on desktop) -->
        <div class="header-contact">
          <a href="tel:1300000000" class="header-phone">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            1300 XXX XXX
          </a>
          <span class="header-hours">Mon–Fri 7am–5pm</span>
        </div>

        <!-- Mobile Menu Toggle -->
        <button class="mobile-toggle" aria-label="Open menu" aria-expanded="false">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>

      <!-- Mobile Navigation Drawer -->
      <nav class="nav-mobile" aria-label="Mobile navigation">
        {navLinks.map((link) => (
          <a href={link.href} class="nav-mobile-link">{link.label}</a>
        ))}
        <a href="tel:1300000000" class="nav-mobile-phone">
          1300 XXX XXX
          <span>Mon–Fri 7am–5pm</span>
        </a>
      </nav>
    </header>

    <!-- ========== MAIN CONTENT ========== -->
    <main>
      <slot />
    </main>

    <!-- ========== FOOTER ========== -->
    <footer class="site-footer">
      <div class="container footer-grid">
        <!-- Column 1: Company Info -->
        <div class="footer-col">
          <img
            src="/images/SecureWorks Group White.svg"
            alt="SecureWorks Group"
            width="160"
            height="36"
            class="footer-logo"
          />
          <p class="footer-tagline">
            Perth's outdoor living specialists. Patios, fencing, decking & more.
          </p>
          <div class="footer-contact-info">
            <a href="tel:1300000000">1300 XXX XXX</a>
            <a href="mailto:info@secureworksgroup.com.au">info@secureworksgroup.com.au</a>
          </div>
        </div>

        <!-- Column 2: Services -->
        <div class="footer-col">
          <h4 class="footer-heading">Services</h4>
          <ul>
            <li><a href="/patios-perth/">Insulated Patios</a></li>
            <li><a href="/patios-perth/">Non-Insulated Patios</a></li>
            <li><a href="/fencing-perth/">Colorbond Fencing</a></li>
            <li><a href="/decking-perth/">Composite Decking</a></li>
            <li><a href="/decking-perth/">Hardwood Decking</a></li>
          </ul>
        </div>

        <!-- Column 3: Service Areas -->
        <div class="footer-col">
          <h4 class="footer-heading">Service Areas</h4>
          <ul>
            {serviceAreas.map((area) => (
              <li>{area}</li>
            ))}
          </ul>
        </div>

        <!-- Column 4: Quick Links + Social -->
        <div class="footer-col">
          <h4 class="footer-heading">Company</h4>
          <ul>
            <li><a href="/about/">About Us</a></li>
            <li><a href="/projects/">Our Projects</a></li>
            <li><a href="/contact/">Contact</a></li>
          </ul>
          <div class="footer-social">
            <a href="https://www.facebook.com/secureworkswa" target="_blank" rel="noopener" aria-label="Facebook">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
              </svg>
            </a>
            <a href="https://www.instagram.com/secureworkswa" target="_blank" rel="noopener" aria-label="Instagram">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Footer Bottom -->
      <div class="container footer-bottom">
        <p>&copy; {new Date().getFullYear()} SecureWorks WA Pty Ltd (ABN: 64 689 223 416). All rights reserved.</p>
      </div>
    </footer>

    <!-- Animation Script -->
    <script src="../scripts/animations.js"></script>
  </body>
</html>

<style>
  /* ========== HEADER ========== */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid transparent;
    height: var(--header-height);
    transition: background 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease, opacity 0.8s ease, transform 0.8s ease;
  }

  /* Hidden during hero video playback — revealed when video ends */
  :global([data-hero-video]) .site-header {
    opacity: 0;
    transform: translateY(-100%);
  }

  .site-header.is-scrolled {
    background: rgba(255, 255, 255, 0.95);
    border-bottom-color: var(--tint);
    box-shadow: 0 1px 12px rgba(41, 60, 70, 0.06);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--header-height);
  }

  .logo img {
    height: 36px;
    width: auto;
  }

  /* Desktop Nav */
  .nav-desktop {
    display: flex;
    gap: 1.5rem;
  }

  .nav-link {
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--dark-blue);
    transition: color var(--transition-fast);
    padding: 0.25rem 0;
    border-bottom: 2px solid transparent;
  }

  .nav-link:hover {
    color: var(--orange);
    border-bottom-color: var(--orange);
  }

  /* Header Contact (Phone + Hours) */
  .header-contact {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  .header-phone {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-weight: 700;
    font-size: 1rem;
    color: var(--dark-blue);
    transition: color var(--transition-fast);
  }

  .header-phone:hover {
    color: var(--orange);
  }

  .header-hours {
    font-size: 0.75rem;
    color: var(--mid-blue);
  }

  /* Mobile Toggle */
  .mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 0.5rem;
  }

  .mobile-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--dark-blue);
    border-radius: 2px;
    transition: transform var(--transition-base), opacity var(--transition-base);
  }

  /* Mobile Nav Drawer */
  .nav-mobile {
    display: none;
    flex-direction: column;
    background: var(--white);
    border-top: 1px solid var(--tint);
    padding: var(--space-sm);
  }

  .nav-mobile.is-open {
    display: flex;
  }

  .nav-mobile-link {
    padding: 0.75rem var(--space-sm);
    font-weight: 600;
    font-size: 1.1rem;
    color: var(--dark-blue);
    border-bottom: 1px solid var(--tint);
  }

  .nav-mobile-phone {
    padding: var(--space-sm);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--orange);
    text-align: center;
    margin-top: var(--space-xs);
  }

  .nav-mobile-phone span {
    display: block;
    font-weight: 400;
    font-size: 0.8rem;
    color: var(--mid-blue);
    margin-top: 0.25rem;
  }

  /* Responsive: hide desktop nav, show mobile toggle */
  @media (max-width: 768px) {
    .nav-desktop,
    .header-contact {
      display: none;
    }

    .mobile-toggle {
      display: flex;
    }
  }

  /* Push main content below fixed header */
  :global(main) {
    padding-top: var(--header-height);
    transition: padding-top 0.8s ease;
  }

  /* During hero video: remove padding so video is truly full-screen */
  :global([data-hero-video]) :global(main) {
    padding-top: 0;
  }

  /* ========== FOOTER ========== */
  .site-footer {
    background: var(--dark-blue);
    color: rgba(255, 255, 255, 0.8);
    padding-top: var(--space-xl);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: var(--space-lg);
  }

  .footer-logo {
    height: 32px;
    width: auto;
    margin-bottom: var(--space-sm);
  }

  .footer-tagline {
    font-size: 0.9375rem;
    margin-bottom: var(--space-sm);
    line-height: 1.5;
  }

  .footer-contact-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .footer-contact-info a {
    color: var(--orange);
    font-weight: 600;
    transition: opacity var(--transition-fast);
  }

  .footer-contact-info a:hover {
    opacity: 0.8;
  }

  .footer-heading {
    color: var(--white);
    font-size: 1rem;
    margin-bottom: var(--space-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .footer-col ul {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .footer-col li {
    font-size: 0.875rem;
  }

  .footer-col a {
    transition: color var(--transition-fast);
  }

  .footer-col a:hover {
    color: var(--white);
  }

  .footer-social {
    display: flex;
    gap: 0.75rem;
    margin-top: var(--space-sm);
  }

  .footer-social a {
    color: rgba(255, 255, 255, 0.6);
    transition: color var(--transition-fast);
  }

  .footer-social a:hover {
    color: var(--orange);
  }

  .footer-bottom {
    margin-top: var(--space-lg);
    padding-block: var(--space-sm);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-bottom p {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.5);
    text-align: center;
  }

  /* Footer responsive */
  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-md);
    }
  }

  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Mobile menu toggle
  function initMobileMenu() {
    const toggle = document.querySelector('.mobile-toggle');
    const mobileNav = document.querySelector('.nav-mobile');

    if (!toggle || !mobileNav) return;

    toggle.addEventListener('click', () => {
      const isOpen = mobileNav.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', String(isOpen));
    });

    // Close mobile menu on link click
    mobileNav.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        mobileNav.classList.remove('is-open');
        toggle.setAttribute('aria-expanded', 'false');
      });
    });
  }

  // Run on initial load
  initMobileMenu();

  // Re-run after View Transitions swap
  document.addEventListener('astro:after-swap', initMobileMenu);

  // Header scroll effect
  function initHeaderScroll() {
    const header = document.querySelector('.site-header');
    if (!header) return;

    function checkScroll() {
      if (window.scrollY > 20) {
        header.classList.add('is-scrolled');
      } else {
        header.classList.remove('is-scrolled');
      }
    }

    window.addEventListener('scroll', checkScroll, { passive: true });
    checkScroll();
  }

  initHeaderScroll();
  document.addEventListener('astro:after-swap', initHeaderScroll);
</script>
