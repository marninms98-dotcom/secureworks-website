---
/**
 * CaseStudy.astro — Broader project gallery
 * Sits directly below the hero. Dense photo grid showing
 * a range of projects + team photos to build credibility.
 * The bush project is already showcased in the hero slideshow,
 * so this section broadens out to show variety.
 */
---

<section class="case-study" id="case-study">
  <div class="case-study__grain" aria-hidden="true"></div>

  <!-- Section intro -->
  <div class="case-study__header">
    <span class="label">Our Work</span>
    <h2 class="case-study__title">Built Across Perth</h2>
    <p class="case-study__sub">
      Patios, decking, fencing, and outdoor kitchens — from suburban backyards to bush properties.
    </p>
  </div>

  <!-- Dense photo grid — all landscape, no portrait issues -->
  <div class="case-study__grid">

    <!-- Row 1: wide + regular -->
    <div class="case-study__item case-study__item--wide">
      <img
        src="/images/gable-patio-decking-downlights.jpg"
        alt="Gable patio with merbau decking and downlights at dusk"
        loading="lazy"
      />
      <div class="case-study__caption">
        <span class="case-study__tag">Patio</span>
        Gable patio + merbau decking + downlights
      </div>
    </div>

    <div class="case-study__item">
      <img
        src="/images/patio-decking-garden.jpg"
        alt="Flat patio with composite decking and landscaped garden"
        loading="lazy"
      />
      <div class="case-study__caption">
        <span class="case-study__tag">Patio</span>
        Flat patio + composite decking
      </div>
    </div>

    <!-- Row 2: three regular -->
    <div class="case-study__item">
      <img
        src="/images/gable-patio-decking-new.jpg"
        alt="Gable patio with composite decking, pool fencing and downlights"
        loading="lazy"
      />
      <div class="case-study__caption">
        <span class="case-study__tag">Patio</span>
        Gable patio + decking + pool fencing
      </div>
    </div>

    <div class="case-study__item">
      <img
        src="/images/team-group-branded.jpg"
        alt="SecureWorks team in branded uniforms"
        loading="lazy"
      />
      <div class="case-study__caption">
        <span class="case-study__tag">Team</span>
        The SecureWorks crew
      </div>
    </div>

    <div class="case-study__item">
      <img
        src="/images/poolside-patio-luxury.jpg"
        alt="Poolside patio with luxury outdoor living setup"
        loading="lazy"
      />
      <div class="case-study__caption">
        <span class="case-study__tag">Patio</span>
        Poolside patio
      </div>
    </div>

    <!-- Row 3: regular + wide -->
    <div class="case-study__item">
      <img
        src="/images/flyover-patio-exterior.jpg"
        alt="Flyover patio exterior view"
        loading="lazy"
      />
      <div class="case-study__caption">
        <span class="case-study__tag">Patio</span>
        Flyover patio
      </div>
    </div>

    <div class="case-study__item case-study__item--wide">
      <img
        src="/images/elevated-patio-exterior.jpg"
        alt="Elevated patio with steel posts on sloped block"
        loading="lazy"
      />
      <div class="case-study__caption">
        <span class="case-study__tag">Patio</span>
        Elevated patio on sloped block
      </div>
    </div>

    <!-- Row 4: three regular -->
    <div class="case-study__item">
      <img
        src="/images/deck-patio-golden.jpg"
        alt="Composite decking with patio at golden hour"
        loading="lazy"
      />
      <div class="case-study__caption">
        <span class="case-study__tag">Decking</span>
        Composite decking at golden hour
      </div>
    </div>

    <div class="case-study__item">
      <img
        src="/images/colorbond-fence-lattice-wide.jpg"
        alt="Colorbond fencing with lattice top extension"
        loading="lazy"
      />
      <div class="case-study__caption">
        <span class="case-study__tag">Fencing</span>
        Colorbond + lattice top
      </div>
    </div>

    <div class="case-study__item">
      <img
        src="/images/bush-patio-exterior-clouds.jpg"
        alt="Flyover patio and merbau deck — bush property with blue sky"
        loading="lazy"
      />
      <div class="case-study__caption">
        <span class="case-study__tag">Patio</span>
        Bush property — patio + deck
      </div>
    </div>

  </div>

  <!-- Stats strip — company-wide -->
  <div class="case-study__stats">
    <div class="case-study__stat">
      <span class="case-study__stat-number">300+</span>
      <span class="case-study__stat-label">Jobs Completed</span>
    </div>
    <div class="case-study__stat-divider" aria-hidden="true"></div>
    <div class="case-study__stat">
      <span class="case-study__stat-number">59%</span>
      <span class="case-study__stat-label">Repeat Customers</span>
    </div>
    <div class="case-study__stat-divider" aria-hidden="true"></div>
    <div class="case-study__stat">
      <span class="case-study__stat-number">4</span>
      <span class="case-study__stat-label">Year Track Record</span>
    </div>
    <div class="case-study__stat-divider" aria-hidden="true"></div>
    <div class="case-study__stat">
      <span class="case-study__stat-number">Perth</span>
      <span class="case-study__stat-label">Based & Built</span>
    </div>
  </div>

  <!-- CTA -->
  <div class="case-study__cta">
    <a href="/projects/" class="btn btn--primary">See All Projects</a>
  </div>
</section>

<style>
  .case-study {
    position: relative;
    background: var(--near-black);
    color: var(--white);
    padding: var(--space-lg) 0 var(--space-md);
    overflow: hidden;
  }

  .case-study__grain {
    position: absolute;
    inset: 0;
    z-index: 1;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    pointer-events: none;
  }

  /* Header */
  .case-study__header {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 680px;
    margin: 0 auto var(--space-md);
    padding-inline: var(--space-sm);
  }

  .case-study__header .label {
    display: inline-block;
    margin-bottom: var(--space-sm);
    color: var(--orange);
  }

  .case-study__title {
    color: var(--white);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-sm);
  }

  .case-study__sub {
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.7;
    max-width: 520px;
    margin-inline: auto;
  }

  /* Photo grid — clean 3-column, all landscape */
  .case-study__grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3px;
    max-width: 1400px;
    margin-inline: auto;
    padding-inline: var(--space-sm);
  }

  /* Wide images span 2 columns */
  .case-study__item--wide {
    grid-column: span 2;
  }

  .case-study__item {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 10;
  }

  .case-study__item--wide {
    aspect-ratio: 21 / 10;
  }

  .case-study__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .case-study__item:hover img {
    transform: scale(1.04);
  }

  /* Caption overlay */
  .case-study__caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1rem 1.25rem;
    background: linear-gradient(0deg, rgba(26, 42, 50, 0.85) 0%, transparent 100%);
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.85);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .case-study__item:hover .case-study__caption {
    opacity: 1;
    transform: translateY(0);
  }

  .case-study__tag {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.2rem 0.5rem;
    background: rgba(241, 90, 41, 0.8);
    color: var(--white);
    flex-shrink: 0;
  }

  /* Project stats */
  .case-study__stats {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-sm) 0;
    max-width: 800px;
    margin-inline: auto;
  }

  .case-study__stat {
    text-align: center;
  }

  .case-study__stat-number {
    display: block;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    color: var(--orange);
    line-height: 1.1;
    font-family: var(--font-heading);
    letter-spacing: -0.02em;
  }

  .case-study__stat-number sup {
    font-size: 0.5em;
    vertical-align: super;
  }

  .case-study__stat-label {
    display: block;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.55);
    margin-top: 0.375rem;
    font-weight: 500;
  }

  .case-study__stat-divider {
    width: 1px;
    height: 40px;
    background: linear-gradient(180deg, transparent, rgba(255, 255, 255, 0.15), transparent);
    flex-shrink: 0;
  }

  /* CTA */
  .case-study__cta {
    position: relative;
    z-index: 2;
    text-align: center;
    padding-top: var(--space-md);
  }

  /* ========== RESPONSIVE ========== */
  @media (max-width: 768px) {
    .case-study {
      padding: var(--space-lg) 0 var(--space-md);
    }

    .case-study__grid {
      grid-template-columns: 1fr;
      gap: 3px;
    }

    .case-study__item--wide {
      grid-column: 1;
    }

    .case-study__item,
    .case-study__item--wide {
      aspect-ratio: 16 / 10;
    }

    /* Show captions on mobile (no hover) */
    .case-study__caption {
      opacity: 1;
      transform: translateY(0);
    }

    .case-study__stats {
      flex-wrap: wrap;
      gap: var(--space-md);
    }

    .case-study__stat-divider {
      display: none;
    }

    .case-study__stat {
      flex: 1 1 40%;
    }
  }
</style>
