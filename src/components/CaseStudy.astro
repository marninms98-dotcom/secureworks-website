---
/**
 * CaseStudy.astro — Bush property transformation showcase
 * Sits directly below the hero. Shows real construction photos
 * in a cinematic editorial layout to immediately build credibility.
 * Before → During → After progression.
 */
---

<section class="case-study" id="case-study">
  <div class="case-study__grain" aria-hidden="true"></div>

  <!-- Section intro -->
  <div class="case-study__header">
    <span class="label">Real Project</span>
    <h2 class="case-study__title">One Backyard.<br>Complete Transformation.</h2>
    <p class="case-study__sub">
      Flyover patio, wraparound merbau deck, and carport — built from bare dirt
      in the Perth hills.
    </p>
  </div>

  <!-- Photo grid — editorial asymmetric layout -->
  <div class="case-study__grid">

    <!-- Large hero shot — completed aerial -->
    <div class="case-study__item case-study__item--hero">
      <img
        src="/images/drone-bush-patio-aerial.jpg"
        alt="Aerial drone view of completed bush property — flyover patio, merbau deck, and carport surrounded by eucalyptus"
        loading="lazy"
        width="1280"
        height="720"
      />
      <div class="case-study__caption">
        <span class="case-study__tag">Completed</span>
        Aerial view — flyover patio, wraparound deck & carport
      </div>
    </div>

    <!-- During construction -->
    <div class="case-study__item case-study__item--tall">
      <img
        src="/images/aerial-patio-construction.jpg"
        alt="Patio steel frame and posts going up during construction"
        loading="lazy"
        width="720"
        height="960"
      />
      <div class="case-study__caption">
        <span class="case-study__tag">During</span>
        Steel frame taking shape
      </div>
    </div>

    <!-- Interior ceiling detail -->
    <div class="case-study__item">
      <img
        src="/images/bush-patio-interior-ceiling.jpg"
        alt="Insulated patio ceiling interior with V-line panels and downlights"
        loading="lazy"
        width="960"
        height="720"
      />
      <div class="case-study__caption">
        <span class="case-study__tag">Detail</span>
        SolarSpan ceiling with integrated downlights
      </div>
    </div>

    <!-- Deck close-up -->
    <div class="case-study__item">
      <img
        src="/images/drone-bush-patio-deck.jpg"
        alt="Merbau deck and patio from drone angle showing the completed outdoor living space"
        loading="lazy"
        width="960"
        height="720"
      />
      <div class="case-study__caption">
        <span class="case-study__tag">Completed</span>
        Merbau deck wraps the full entertaining area
      </div>
    </div>

    <!-- Bush exterior -->
    <div class="case-study__item case-study__item--wide">
      <img
        src="/images/verandah-bush-exterior.jpg"
        alt="Completed verandah and patio exterior in bush setting with eucalyptus trees"
        loading="lazy"
        width="1280"
        height="720"
      />
      <div class="case-study__caption">
        <span class="case-study__tag">Completed</span>
        The finished space sits naturally in the bush landscape
      </div>
    </div>

  </div>

  <!-- Stats strip for this project -->
  <div class="case-study__stats">
    <div class="case-study__stat">
      <span class="case-study__stat-number">8</span>
      <span class="case-study__stat-label">Week Build</span>
    </div>
    <div class="case-study__stat-divider" aria-hidden="true"></div>
    <div class="case-study__stat">
      <span class="case-study__stat-number">65m<sup>2</sup></span>
      <span class="case-study__stat-label">Patio Area</span>
    </div>
    <div class="case-study__stat-divider" aria-hidden="true"></div>
    <div class="case-study__stat">
      <span class="case-study__stat-number">40m<sup>2</sup></span>
      <span class="case-study__stat-label">Merbau Deck</span>
    </div>
    <div class="case-study__stat-divider" aria-hidden="true"></div>
    <div class="case-study__stat">
      <span class="case-study__stat-number">R1.8</span>
      <span class="case-study__stat-label">Insulation Rating</span>
    </div>
  </div>

  <!-- More of our work — horizontal scroll strip -->
  <div class="case-study__more">
    <h3 class="case-study__more-title">More Of Our Work</h3>
    <div class="case-study__scroll-strip">
      <div class="case-study__scroll-item">
        <img src="/images/gable-patio-decking-downlights.jpg" alt="Gable patio with merbau decking and downlights" loading="lazy" />
        <span class="case-study__scroll-label">Gable Patio + Decking</span>
      </div>
      <div class="case-study__scroll-item">
        <img src="/images/colorbond-fence-lattice-wide.jpg" alt="Colorbond fencing with lattice top" loading="lazy" />
        <span class="case-study__scroll-label">Colorbond Fencing</span>
      </div>
      <div class="case-study__scroll-item">
        <img src="/images/flyover-patio-exterior.jpg" alt="Flyover patio exterior view" loading="lazy" />
        <span class="case-study__scroll-label">Flyover Patio</span>
      </div>
      <div class="case-study__scroll-item">
        <img src="/images/team-crew-thumbsup.jpg" alt="SecureWorks crew giving thumbs up on site" loading="lazy" />
        <span class="case-study__scroll-label">The Crew</span>
      </div>
      <div class="case-study__scroll-item">
        <img src="/images/flat-patio-decking-downlights.jpg" alt="Flat insulated patio with decking and downlights at night" loading="lazy" />
        <span class="case-study__scroll-label">Flat Patio + Lights</span>
      </div>
      <div class="case-study__scroll-item">
        <img src="/images/poolside-patio-luxury.jpg" alt="Poolside patio with luxury outdoor living setup" loading="lazy" />
        <span class="case-study__scroll-label">Poolside Patio</span>
      </div>
      <div class="case-study__scroll-item">
        <img src="/images/deck-patio-golden.jpg" alt="Composite decking with patio at golden hour" loading="lazy" />
        <span class="case-study__scroll-label">Decking</span>
      </div>
      <div class="case-study__scroll-item">
        <img src="/images/team-group-branded.jpg" alt="SecureWorks team in branded uniforms" loading="lazy" />
        <span class="case-study__scroll-label">Our Team</span>
      </div>
      <div class="case-study__scroll-item">
        <img src="/images/freestanding-patio-outdoor-kitchen.jpg" alt="Freestanding patio with outdoor kitchen setup" loading="lazy" />
        <span class="case-study__scroll-label">Outdoor Kitchen</span>
      </div>
      <div class="case-study__scroll-item">
        <img src="/images/two-storey-balcony-front.jpg" alt="Two storey balcony patio build" loading="lazy" />
        <span class="case-study__scroll-label">Two Storey Balcony</span>
      </div>
    </div>
  </div>

  <!-- CTA -->
  <div class="case-study__cta">
    <a href="/projects/" class="btn btn--primary">See More Projects</a>
  </div>
</section>

<style>
  .case-study {
    position: relative;
    background: var(--near-black);
    color: var(--white);
    padding: var(--space-xl) 0 var(--space-lg);
    overflow: hidden;
  }

  .case-study__grain {
    position: absolute;
    inset: 0;
    z-index: 1;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    pointer-events: none;
  }

  /* Header */
  .case-study__header {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 680px;
    margin: 0 auto var(--space-lg);
    padding-inline: var(--space-sm);
  }

  .case-study__header .label {
    display: inline-block;
    margin-bottom: var(--space-sm);
    color: var(--orange);
  }

  .case-study__title {
    color: var(--white);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-sm);
  }

  .case-study__sub {
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.7;
    max-width: 520px;
    margin-inline: auto;
  }

  /* Photo grid — asymmetric editorial */
  .case-study__grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    grid-template-rows: auto auto auto;
    gap: 4px;
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: var(--space-sm);
  }

  /* Hero image spans full width */
  .case-study__item--hero {
    grid-column: 1 / -1;
  }

  /* Tall image spans 2 rows on right */
  .case-study__item--tall {
    grid-row: span 2;
  }

  /* Wide image spans full width */
  .case-study__item--wide {
    grid-column: 1 / -1;
  }

  .case-study__item {
    position: relative;
    overflow: hidden;
  }

  .case-study__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .case-study__item:hover img {
    transform: scale(1.04);
  }

  /* Caption overlay */
  .case-study__caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1rem 1.25rem;
    background: linear-gradient(0deg, rgba(26, 42, 50, 0.85) 0%, transparent 100%);
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.85);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .case-study__item:hover .case-study__caption {
    opacity: 1;
    transform: translateY(0);
  }

  .case-study__tag {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.2rem 0.5rem;
    background: rgba(241, 90, 41, 0.8);
    color: var(--white);
    flex-shrink: 0;
  }

  /* Project stats */
  .case-study__stats {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-lg);
    padding: var(--space-lg) var(--space-sm) 0;
    max-width: 800px;
    margin-inline: auto;
  }

  .case-study__stat {
    text-align: center;
  }

  .case-study__stat-number {
    display: block;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    color: var(--orange);
    line-height: 1.1;
    font-family: var(--font-heading);
    letter-spacing: -0.02em;
  }

  .case-study__stat-number sup {
    font-size: 0.5em;
    vertical-align: super;
  }

  .case-study__stat-label {
    display: block;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.55);
    margin-top: 0.375rem;
    font-weight: 500;
  }

  .case-study__stat-divider {
    width: 1px;
    height: 40px;
    background: linear-gradient(180deg, transparent, rgba(255, 255, 255, 0.15), transparent);
    flex-shrink: 0;
  }

  /* More work — horizontal scroll strip */
  .case-study__more {
    position: relative;
    z-index: 2;
    padding: var(--space-lg) 0 0;
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: var(--space-sm);
  }

  .case-study__more-title {
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-sm);
  }

  .case-study__scroll-strip {
    display: flex;
    gap: 4px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: var(--space-sm);
  }

  .case-study__scroll-strip::-webkit-scrollbar {
    display: none;
  }

  .case-study__scroll-item {
    flex: 0 0 280px;
    scroll-snap-align: start;
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }

  .case-study__scroll-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .case-study__scroll-item:hover img {
    transform: scale(1.06);
  }

  .case-study__scroll-label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.75rem 1rem;
    background: linear-gradient(0deg, rgba(26, 42, 50, 0.8) 0%, transparent 100%);
    font-size: 0.8rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
  }

  /* CTA */
  .case-study__cta {
    position: relative;
    z-index: 2;
    text-align: center;
    padding-top: var(--space-lg);
  }

  /* ========== RESPONSIVE ========== */
  @media (max-width: 768px) {
    .case-study {
      padding: var(--space-lg) 0 var(--space-md);
    }

    .case-study__grid {
      grid-template-columns: 1fr;
      gap: 3px;
    }

    .case-study__item--hero,
    .case-study__item--wide {
      grid-column: 1;
    }

    .case-study__item--tall {
      grid-row: span 1;
    }

    /* Show captions on mobile (no hover) */
    .case-study__caption {
      opacity: 1;
      transform: translateY(0);
    }

    .case-study__stats {
      flex-wrap: wrap;
      gap: var(--space-md);
    }

    .case-study__stat-divider {
      display: none;
    }

    .case-study__stat {
      flex: 1 1 40%;
    }
  }
</style>
