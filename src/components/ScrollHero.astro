---
/**
 * ScrollHero.astro — Cinematic video intro + auto-sliding gallery hero
 *
 * Sequence:
 * 1. Video plays full-screen, NO text, NO header — pure immersion
 * 2. Video ends → fades to first gallery slide (completed aerial)
 * 3. Text staggers in (eyebrow → heading → sub → buttons)
 * 4. Header fades in from top
 * 5. Background becomes auto-sliding gallery of bush project photos
 *    with crossfade + Ken Burns — hero stays alive, never static
 *
 * Mobile: skips video, shows slideshow with text immediately.
 */

const slides = [
  { src: "/images/bush-patio-interior-ceiling.jpg", alt: "Insulated SolarSpan ceiling with V-line panels and integrated downlights" },
  { src: "/images/drone-bush-patio-deck.jpg", alt: "Merbau deck and patio from above — completed outdoor living space" },
  { src: "/images/verandah-bush-exterior.jpg", alt: "Completed verandah and patio exterior surrounded by eucalyptus" },
  { src: "/images/verandah-bush-interior.jpg", alt: "Interior view looking out from under the insulated patio to the bush" },
];
---

<!-- Immediately hide header on desktop before paint — prevents flash -->
<script is:inline>
  if (window.innerWidth > 768) {
    document.documentElement.setAttribute('data-hero-video', '');
  }
</script>

<section class="scroll-hero" id="scroll-hero">
  <!-- Autoplay video — plays once, no loop -->
  <video
    class="scroll-hero__video"
    autoplay
    muted
    playsinline
    preload="auto"
    poster="/frames/frame_0000.webp"
  >
    <source src="/video/hero-transformation.mp4" type="video/mp4" />
  </video>

  <!-- Auto-sliding gallery — crossfades behind text after video ends -->
  <div class="scroll-hero__slideshow">
    {slides.map((slide, i) => (
      <div class={`scroll-hero__slide ${i === 0 ? 'is-active' : ''}`}>
        <img
          src={slide.src}
          alt={slide.alt}
          width="1920"
          height="1080"
          loading={i === 0 ? "eager" : "lazy"}
        />
      </div>
    ))}
  </div>

  <!-- Mobile fallback — first slide shown immediately -->
  <div class="scroll-hero__fallback">
    <img
      src="/images/drone-bush-patio-aerial.jpg"
      alt="Aerial view of completed bush property transformation"
      width="1280"
      height="716"
      fetchpriority="high"
    />
  </div>

  <!-- Overlay — starts minimal during video, strengthens when text appears -->
  <div class="scroll-hero__overlay"></div>
  <div class="scroll-hero__grain" aria-hidden="true"></div>

  <!-- Hero content — hidden during video, revealed after -->
  <div class="scroll-hero__content">
    <span class="hero__eyebrow label hero__reveal" style="--i:0">Perth's Outdoor Living Builders</span>
    <h1 class="hero__heading hero__reveal" style="--i:1">The Best Part of Your Home<br>Isn't Built Yet</h1>
    <p class="hero__sub hero__reveal" style="--i:2">
      Add liveable space to your home for a fraction of the cost of a traditional
      extension — and it'll be the room your family uses most. Patio, deck, and
      fencing designed and built by one team.
    </p>
    <div class="hero__actions hero__reveal" style="--i:3">
      <a href="/contact/" class="btn btn--primary btn--glow">Book a Free Site Visit</a>
      <a href="/projects/" class="btn btn--outline btn--glass">See Our Work</a>
    </div>
  </div>

  <!-- Scroll cue -->
  <div class="scroll-hero__scroll-cue">
    <div class="hero__scroll-line"></div>
  </div>
</section>

<script>
  function initHeroSequence() {
    const hero = document.querySelector('.scroll-hero');
    const video = document.querySelector('.scroll-hero__video') as HTMLVideoElement;
    const slides = document.querySelectorAll('.scroll-hero__slide');
    if (!hero) return;

    const isDesktop = window.innerWidth > 768;
    let slideshowInterval: ReturnType<typeof setInterval>;

    // --- SLIDESHOW ENGINE ---
    // Crossfades between slides with Ken Burns zoom (CSS handles the zoom)
    function startSlideshow() {
      if (slides.length < 2) return;
      let current = 0;

      slideshowInterval = setInterval(() => {
        const prev = current;
        current = (current + 1) % slides.length;

        // Fade out previous, fade in next
        slides[prev].classList.remove('is-active');
        slides[current].classList.add('is-active');
      }, 5000); // 5s per slide
    }

    function revealAll() {
      hero.classList.add('is-revealed');
      document.documentElement.removeAttribute('data-hero-video');
      // Start slideshow after text has finished staggering in (~1.2s)
      setTimeout(startSlideshow, 1500);
    }

    if (isDesktop && video) {
      // --- DESKTOP: Cinematic sequence ---
      video.loop = false;

      // Dynamic crop compensation — counteracts camera drifting the house lower.
      const startScale = 1.28;
      const endScale = 1.18;
      let rafId: number;

      video.style.transform = `scale(${startScale})`;

      function updateVideoCrop() {
        if (!video.duration || video.paused || video.ended) return;
        const progress = video.currentTime / video.duration;
        const timeLeft = video.duration - video.currentTime;

        const scale = startScale + (endScale - startScale) * progress;
        const originY = progress * 25;
        video.style.transform = `scale(${scale})`;
        video.style.transformOrigin = `center ${originY}%`;

        // Fade out over last 1.5s for smooth transition to slideshow beneath
        if (timeLeft < 1.5) {
          video.style.opacity = String(Math.max(timeLeft / 1.5, 0));
        }

        rafId = requestAnimationFrame(updateVideoCrop);
      }

      video.addEventListener('play', () => {
        rafId = requestAnimationFrame(updateVideoCrop);
      });

      video.addEventListener('ended', () => cancelAnimationFrame(rafId));
      video.addEventListener('pause', () => cancelAnimationFrame(rafId));

      // When video ends: reveal text + header + start slideshow
      video.addEventListener('ended', revealAll);

      video.addEventListener('error', revealAll);

      // Fallback timeout
      setTimeout(() => {
        if (!hero.classList.contains('is-revealed')) revealAll();
      }, 12000);

    } else {
      // --- MOBILE: Skip video, show everything + slideshow immediately ---
      hero.classList.add('is-revealed', 'is-mobile');
      document.documentElement.removeAttribute('data-hero-video');
      startSlideshow();
    }

    // Cleanup on page transition
    document.addEventListener('astro:before-swap', () => {
      clearInterval(slideshowInterval);
    }, { once: true });
  }

  initHeroSequence();
  document.addEventListener('astro:after-swap', initHeroSequence);
</script>

<style>
  .scroll-hero {
    position: relative;
    height: 100vh;
    min-height: 600px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ===== VIDEO (desktop only) ===== */
  .scroll-hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 0%;
    z-index: 1;
    /* Starting state — JS dynamically adjusts scale + origin
       during playback to counteract camera drift */
    transform: scale(1.28);
    transform-origin: center 0%;
    will-change: transform, opacity;
  }

  /* ===== AUTO-SLIDING GALLERY (behind text, after video ends) ===== */
  .scroll-hero__slideshow {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .scroll-hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    z-index: 0;
    transition: opacity 1.2s ease;
  }

  /* Slides stack — each new active slide fades in ON TOP.
     No fade-out = no white flash between transitions. */
  .scroll-hero__slide.is-active {
    opacity: 1;
    z-index: 1;
  }

  .scroll-hero__slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    /* Slight overscale so object-fit has room — no zoom animation */
    transform: scale(1.02);
  }

  /* ===== MOBILE FALLBACK ===== */
  .scroll-hero__fallback {
    display: none;
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .scroll-hero__fallback img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ===== OVERLAY ===== */
  /* Starts subtle during video, strengthens when text appears */
  .scroll-hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    opacity: 0.15;
    background:
      radial-gradient(ellipse at 50% 45%, rgba(26, 42, 50, 0.45) 0%, transparent 65%),
      linear-gradient(180deg, rgba(26, 42, 50, 0.15) 0%, rgba(26, 42, 50, 0.25) 40%, rgba(26, 42, 50, 0.6) 85%, rgba(26, 42, 50, 0.95) 100%);
    pointer-events: none;
    transition: opacity 1.8s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .scroll-hero.is-revealed .scroll-hero__overlay {
    opacity: 1;
  }

  .scroll-hero__grain {
    position: absolute;
    inset: 0;
    z-index: 3;
    opacity: 0.035;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    pointer-events: none;
  }

  /* ===== HERO CONTENT ===== */
  .scroll-hero__content {
    position: relative;
    z-index: 4;
    text-align: center;
    max-width: 780px;
    padding-inline: var(--space-sm);
    color: var(--white);
  }

  /* Text is invisible until .is-revealed is added */
  .hero__reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: none;
  }

  /* When revealed, stagger each element in */
  .scroll-hero.is-revealed .hero__reveal {
    animation: heroFadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(0.2s + var(--i) * 0.18s);
  }

  @keyframes heroFadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ===== SCROLL CUE ===== */
  .scroll-hero__scroll-cue {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    opacity: 0;
  }

  .scroll-hero.is-revealed .scroll-hero__scroll-cue {
    animation: heroFadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: 1.2s;
  }

  /* ===== HERO TEXT STYLES ===== */
  .hero__eyebrow {
    display: inline-block;
    margin-bottom: var(--space-sm);
    padding: 0.375rem 1rem;
    background: rgba(241, 90, 41, 0.15);
    border: 1px solid rgba(241, 90, 41, 0.3);
    border-radius: var(--radius-pill);
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .hero__heading {
    color: var(--white);
    font-weight: 800;
    font-size: clamp(2.75rem, 7vw, 5rem);
    margin-bottom: var(--space-sm);
    line-height: 1.05;
    letter-spacing: -0.02em;
    text-shadow: 0 2px 30px rgba(0, 0, 0, 0.4), 0 1px 3px rgba(0, 0, 0, 0.3);
  }

  .hero__sub {
    font-size: clamp(1rem, 1.5vw, 1.25rem);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: var(--space-md);
    max-width: 580px;
    margin-inline: auto;
  }

  .hero__actions {
    display: flex;
    gap: var(--space-sm);
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero__scroll-line {
    width: 1px;
    height: 48px;
    background: rgba(255, 255, 255, 0.2);
    position: relative;
    overflow: hidden;
  }

  .hero__scroll-line::after {
    content: '';
    position: absolute;
    top: -100%;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, transparent, var(--orange), transparent);
    animation: scrollLine 2s ease-in-out infinite;
  }

  @keyframes scrollLine {
    0% { top: -100%; }
    100% { top: 200%; }
  }

  /* ===== BUTTON STYLES ===== */
  .btn--glow {
    position: relative;
    box-shadow: 0 0 20px rgba(241, 90, 41, 0.3);
    transition: box-shadow var(--transition-base), background-color var(--transition-fast), transform var(--transition-fast);
  }

  .btn--glow:hover {
    box-shadow: 0 0 30px rgba(241, 90, 41, 0.5);
  }

  .btn--glass {
    border-color: rgba(255, 255, 255, 0.25);
    color: var(--white);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    background: rgba(255, 255, 255, 0.05);
  }

  .btn--glass:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.5);
    color: var(--white);
  }

  /* ===== MOBILE ===== */
  @media (max-width: 768px) {
    .scroll-hero__video {
      display: none;
    }

    .scroll-hero__fallback {
      display: block;
    }

    /* On mobile, text appears immediately (no video to wait for) */
    .scroll-hero.is-mobile .hero__reveal {
      animation-delay: calc(0.1s + var(--i) * 0.12s);
    }

    .hero__heading {
      font-size: clamp(2rem, 8vw, 3rem);
    }

    .hero__actions {
      flex-direction: column;
      width: 100%;
      max-width: 320px;
      margin-inline: auto;
    }

    .hero__actions .btn {
      width: 100%;
    }
  }
</style>
